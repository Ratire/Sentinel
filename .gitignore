# gitignore template for Xilinx Vivado Design Suite
# website: https://www.xilinx.com/support/download.html

# [home]
*.jou
*.log
*.debug
*.str
*.zip
*.tmp
*.rst
*.os
*.js
*.pb
*.dcp
*.hwdef
*.vds
*.veo
*.wdf
*.vdi
*.dmp
*.rpx
*.rpt
*_stub.v
*_stub.vhdl
*_funcsim.v
*_funcsim.vhdl
.project

# [dir]
*.cache
.metadata
*.data
*.ipdefs
.Xil
*.sdk
*.hw
*.ip_user_files


#------------------------
# Vivado Files
#------------------------

### IP synth
*_synth_*

.jobs

### project synth
*/*.runs/synth*/*.xml
*/*.runs/synth*/*.txt
*/*.runs/synth*/*.sh
*/*.runs/synth*/*.tcl
*/*.runs/synth*/*.bat
*/*.runs/synth*/*.xdc
!*/*.runs/synth*/*utilization*.rpt

*.runs/synth*/*.xml
*.runs/synth*/*.txt
*.runs/synth*/*.sh
*.runs/synth*/*.tcl
*.runs/synth*/*.bat
*.runs/synth*/*.xdc
!*.runs/synth*/*utilization*.rpt

### project impl
*/*.runs/impl*/*.xml
*/*.runs/impl*/*.html
*/*.runs/impl*/*.txt
*/*.runs/impl*/*.sh
*/*.runs/impl*/*.tcl
*/*.runs/impl*/*.bat
!*/*.runs/impl*/*utilization*.rpt

*.runs/impl*/*.xml
*.runs/impl*/*.html
*.runs/impl*/*.txt
*.runs/impl*/*.sh
*.runs/impl*/*.tcl
*.runs/impl*/*.bat
!*.runs/impl*/*utilization*.rpt

### block design
*/*/bd/*/hdl
*/*/*/bd/*/hdl

*/*/bd/*/*.xdc
*/*/*/bd/*/*.xdc

*/*/bd/*/ip/*/*.xdc
*/*/*/bd/*/ip/*/*.xdc

*/*/bd/*/ip/*/*/
*/*/*/bd/*/ip/*/*/

*/*/bd/*/ip/*/*.vhd
*/*/*/bd/*/ip/*/*.vhd

*/*/bd/*/ip/*/*.xml
*/*/*/bd/*/ip/*/*.xml

*.c
*.h
*.vho
*.html
*/*/bd/*/ip/*/*.tcl
*/*/*/bd/*/ip/*/*.tcl
hw_handoff
ipshared

# Ignore Vivado project files in build directory only
build/**/*.xpr
build/**/*.cache/
build/**/*.hw/
build/**/*.ip_user_files/


#------------------------
# Fix Paths for Your Project Structure
#------------------------
# Your current gitignore uses 'build/vivado_project/' (singular)
# but your actual path is 'build/vivado_projects/' (plural + project subdir)

# Ignore all generated directories under specific project folders
build/vivado_projects/*/*.gen/
build/vivado_projects/*/*.cache/
build/vivado_projects/*/*.hw/
build/vivado_projects/*/*.ip_user_files/
build/vivado_projects/*/*.runs/
build/vivado_projects/*/*.sim/
build/vivado_projects/*/*.tmp/

# Ignore waveform configs (user-specific IDE settings)
*.wcfg

# Ignore generated reports and schematics (can be regenerated)
build/vivado_projects/*/reports/

# Ignore bitstreams (store in GitHub Releases if needed for demo)
build/vivado_projects/*/*.runs/impl*/*.bit
build/vivado_projects/*/*.runs/impl*/*.bin

#------------------------
# Whitelist: Keep Vivado Project Sources
#------------------------
# IMPORTANT: You need these to recreate the project later
!build/vivado_projects/*/*.srcs/
!build/vivado_projects/*/*.xpr
!build/vivado_projects/*/*.bd
!build/vivado_projects/*/Waveforms/*.wcfg

# Keep the hw_handoff for Vitis (you already have this, but ensure it works)
!build/hw_handoff/
!build/hw_handoff/*.xsa


#------------------------
# Vitis Workspace & BSP Build Artifacts
#------------------------

# Ignore CONTENTS of vitis_workspace but allow directory traversal for whitelisting
build/vitis_workspace/**/*

# IDE session files
**/_ide/
**/.peers.ini
**/.vitisPlatformRepo.json
**/workspace_journal*.py
**/logs/

# BSP Build Configurations
**/build_configs/
**/.ninja_log
**/.ninja_deps
**/build.ninja
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/compile_commands.json
**/.clangd

# Compiled Libraries & Objects
*.a
*.obj
*.elf
*.elf.size
*.mri

# Hardware Specification Artifacts (general)
*.dts
*.dtsi
**/hw/sdt/
**/hw_artifacts/
**/zynqmp_fsbl/
**/psu_cortexa53_*/
**/standalone_psu_*/

# Application metadata
**/vitis-comp.json
**/app.yaml
**/bsp.yaml

#------------------------
# Whitelist: Keep Actual Source Code
#------------------------

# Your C application source (must come AFTER the /**/* ignore above)
!build/vitis_workspace/fft_test_app/src/
!build/vitis_workspace/fft_test_app/src/main.c
!build/vitis_workspace/fft_test_app/src/golden_vectors.h

# Hardware Specification (needed to recreate platform)
!build/hw_handoff/
!build/hw_handoff/*.xsa

# Keep ignoring generated files even in whitelisted src/
build/vitis_workspace/fft_test_app/src/*.json
build/vitis_workspace/fft_test_app/src/*.ld
build/vitis_workspace/fft_test_app/src/CMakeLists.txt
build/vitis_workspace/fft_test_app/src/*.cmake
build/vitis_workspace/fft_test_app/src/*.yaml
build/vitis_workspace/fft_test_app/src/README.txt
build/vitis_workspace/fft_test_app/src/UserConfig.cmake
build/vitis_workspace/fft_test_app/src/Empty_applicationExample.cmake

#------------------------
# User Additions (by me)
#------------------------

# Simulation directories and files
*.sim/
xsim.dir/

# Waveform database files
*.wdb

# XSim tool artifacts
xsim.*
xvlog.*
xelab.*

# User-specific project settings
*.xpr.user

# Simulation dumps
*.vcd
*.saif

# Extra additions to get rid of the Vivado Project Generated Files
# NOTE: These must match the Whitelist paths above (using vivado_projects plural)
build/vivado_projects/*.gen/
build/vivado_projects/*.cache/
build/vivado_projects/*.hw/
build/vivado_projects/*.ip_user_files/
build/vivado_projects/*.runs/
build/vivado_projects/*.sim/
build/vivado_projects/*.tmp/

# NOTE: The following lines were removed because they block project recreation:
# build/vivado_project/*.xpr  (REMOVED - you need this file!)
# build/vivado_project/Senti.srcs/  (REMOVED - blocks your source files!)

__pycache__/
*.pyc
build/vivado_project/Waveforms/
*.bda
*/ui/*.ui

# Vivado generated artifacts (kept locally but not in git)
build/vivado_project/Senti.gen/
build/vivado_project/Senti.runs/
build/vivado_project/Senti.hw/
build/vivado_project/Senti.ip_user_files/
build/vivado_project/Senti.sim/
build/vivado_projects/*/Senti_*.gen/
build/vivado_projects/*/Senti_*.runs/
build/vivado_projects/*/Senti_*.hw/
build/vivado_projects/*/Senti_*.sim/

# IP component files with absolute paths
src/ip/systolic_array_ip/component.xml

# Vivado project files with absolute paths
build/vivado_projects/*/*.xpr

# Local images/reference files
Images_To_Show/Synthesis_utilization_report.png
Images_To_Show/Synthesis_utilization_report_2.png
Images_To_Show/pdfs/sentinel_bd_FFT_SA.pdf
Images_To_Show/pe_cell.txt
Images_To_Show/pe_cell_code.pdf

build/vivado_projects/systolic_array/Senti_Systolic_Array.srcs/sources_1/new/sentinel_bd_FFT_SA.pdf

#--------------------------------------------------
# Personal Info Protection (remove /home/Rati/ paths)
#--------------------------------------------------

# Vivado IP cache files contain absolute paths (/home/Rati/Desktop/...)
build/vivado_projects/**/*.xci

# Backup TCL files generated by Vivado
*.tcl_1
src/ip/*/component.xml
