# gitignore template for Xilinx Vivado Design Suite
# website: https://www.xilinx.com/support/download.html

# [home]
*.jou
*.log
*.debug
*.str
*.zip
*.tmp
*.rst
*.os
*.js
*.pb
*.dcp
*.hwdef
*.vds
*.veo
*.wdf
*.vdi
*.dmp
*.rpx
*.rpt
*_stub.v
*_stub.vhdl
*_funcsim.v
*_funcsim.vhdl
.project

# [dir]
*.cache
.metadata
*.data
*.ipdefs
.Xil
*.sdk
*.hw
*.ip_user_files


#------------------------
# Vivado Files
#------------------------

### IP synth
*_synth_*

.jobs

### project synth
*/*.runs/synth*/*.xml
*/*.runs/synth*/*.txt
*/*.runs/synth*/*.sh
*/*.runs/synth*/*.tcl
*/*.runs/synth*/*.bat
*/*.runs/synth*/*.xdc
!*/*.runs/synth*/*utilization*.rpt

*.runs/synth*/*.xml
*.runs/synth*/*.txt
*.runs/synth*/*.sh
*.runs/synth*/*.tcl
*.runs/synth*/*.bat
*.runs/synth*/*.xdc
!*.runs/synth*/*utilization*.rpt

### project impl
*/*.runs/impl*/*.xml
*/*.runs/impl*/*.html
*/*.runs/impl*/*.txt
*/*.runs/impl*/*.sh
*/*.runs/impl*/*.tcl
*/*.runs/impl*/*.bat
!*/*.runs/impl*/*utilization*.rpt

*.runs/impl*/*.xml
*.runs/impl*/*.html
*.runs/impl*/*.txt
*.runs/impl*/*.sh
*.runs/impl*/*.tcl
*.runs/impl*/*.bat
!*.runs/impl*/*utilization*.rpt

### block design
*/*/bd/*/hdl
*/*/*/bd/*/hdl

*/*/bd/*/*.xdc
*/*/*/bd/*/*.xdc

*/*/bd/*/ip/*/*.xdc
*/*/*/bd/*/ip/*/*.xdc

*/*/bd/*/ip/*/*/
*/*/*/bd/*/ip/*/*/

*/*/bd/*/ip/*/*.vhd
*/*/*/bd/*/ip/*/*.vhd

*/*/bd/*/ip/*/*.xml
*/*/*/bd/*/ip/*/*.xml

*.c
*.h
*.vho
*.html
*/*/bd/*/ip/*/*.tcl
*/*/*/bd/*/ip/*/*.tcl
hw_handoff
ipshared

#------------------------
# Vitis Workspace & BSP Build Artifacts
#------------------------

# Vitis workspace directories (contains generated IDE files, BSPs, build artifacts)
vitis_workspace/
build/vitis_workspace/
**/_ide/
**/.peers.ini
**/.vitisPlatformRepo.json
**/workspace_journal*.py

# BSP Build Configurations (contains compiled objects, CMake cache, ninja logs)
**/build_configs/
**/.ninja_log
**/.ninja_deps
**/build.ninja
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/compile_commands.json
**/.clangd

# Compiled Libraries & Objects (Vitis BSP generates these)
*.a        # Static libraries (libxil.a, libaxidma.a, etc.)
*.obj      # Object files (BSP compilation)
*.elf      # ARM executables (fsbl.elf, application.elf)
*.elf.size
*.mri      # GNU archiver scripts

# Hardware Specification Artifacts (generated from XSA import)
*.xsa
*.dts
*.dtsi
**/hw/sdt/
**/hw_artifacts/
**/zynqmp_fsbl/           # First Stage Bootloader (generated)
**/psu_cortexa53_*/       # BSP directories for A53 cores
**/standalone_psu_*/      # Standalone BSP directories

# Application metadata (regenerated on import)
**/vitis-comp.json
**/app.yaml
**/bsp.yaml
**/lscript.ld             # Linker script (generated from XSA)

#------------------------
# User Additions (by me)
#------------------------

# Simulation directories and files
*.sim/
xsim.dir/

# Waveform database files
*.wdb

# XSim tool artifacts
xsim.*
xvlog.*
xelab.*

# User-specific project settings
*.xpr.user

# Simulation dumps
*.vcd
*.saif

# Extra additions to get rid of the Vivado Project Generated Files
build/vivado_project/*.gen/
build/vivado_project/*.cache/
build/vivado_project/*.hw/
build/vivado_project/*.ip_user_files/
build/vivado_project/*.runs/
build/vivado_project/*.sim/
build/vivado_project/*.tmp/
build/vivado_project/*.xpr  # Since I don't want to track the project file itself

build/vivado_project/Senti.gen/
build/vivado_project/Senti.srcs/sources_1/new/
__pycache__/
*.pyc
build/vivado_project/Waveforms/
build/vivado_project/Senti.srcs/
build/vivado_project/*.xpr
*.bda
*/ui/*.ui
